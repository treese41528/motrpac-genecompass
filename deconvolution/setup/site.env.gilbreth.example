# =============================================================================
# Per-site profile  --  the ONE place that pins machine-specific paths.
#
# Copy to deconvolution/setup/site.env (gitignored) and edit for YOUR machine:
#   cp deconvolution/setup/site.env.gilbreth.example deconvolution/setup/site.env
#
# It is sourced by deconvolution/setup/site_env.sh, which every R/*.sh wrapper and the
# bootstrap installer load. Every variable is OPTIONAL -- leave one empty and that step
# becomes a no-op. The values below are the working Purdue Gilbreth (Spack/Lmod + system
# Anaconda) profile; use them as a template.
#
#   * On a DIFFERENT module cluster: keep the four vars, swap the module names / conda
#     prefix / python path / data store for your site.
#   * On a LAPTOP or inside the CONTAINER (R + libs already on PATH): you usually need NO
#     site.env at all -- leave R_MODULES/STRIP_CONDA empty and the wrappers just use the R
#     and python already on PATH. (Set MGC_MOTRPAC_DATA_STORE if you stage the bulk data.)
# =============================================================================

# --- (1) Environment modules ------------------------------------------------
# FULL module list to load (in order) before building/running, e.g. R plus the build-time
# system headers the bare conda env lacks. Loaded ONLY if `module` (Lmod) exists -- empty or
# no Lmod => skipped, and R is taken from PATH.
#   libpng -> png.h (Seurat's png dep) | zlib -> zlib.h | cmake -> nloptr
#   (libxml2/curl/libtiff arrive with the r module; openssl/ICU headers come from conda's
#    include dir, which we deliberately keep on CPATH -- see STRIP_CONDA below.)
R_MODULES="r/4.4.1 libpng/1.6.37 zlib/1.3.1 cmake/3.30.2"

# --- (2) Conda strip --------------------------------------------------------
# Conda/Anaconda prefix to drop from PATH + PKG_CONFIG_PATH (NOT CPATH). On Gilbreth the
# system Anaconda's libstdc++ otherwise shadows the module gcc and breaks scran/igraph dlopen.
# Leave empty on a machine without a conflicting conda.
STRIP_CONDA="/apps/external/conda/2025.09"

# --- (3) Project Python interpreter -----------------------------------------
# Python used by reticulate (R<->python bridge) and the omnideconv Python methods
# (AutoGeneS/Scaden). Feeds both ENV_PY (pip install target) and RETICULATE_PYTHON. Point it
# at the project venv (see SETUP.md: python3.12 -m venv motrpac-env). If empty, the wrappers
# fall back to the active venv ($VIRTUAL_ENV) or python3 on PATH.
MGC_PYTHON="/depot/reese18/apps/motrpac-env/bin/python"

# --- (4) MoTrPAC external data store ----------------------------------------
# Where install_motrpac_data.sh stages the MoTrPAC rat-training-6mo data (~18 GiB: 206
# in-package .rda + 58 GCS-hosted .rda). Must be a WRITABLE path OUTSIDE the repo; it gets
# symlinked to data/motrpac/rat_training_6mo. Set this on any machine that is not the author's.
MGC_MOTRPAC_DATA_STORE="/depot/reese18/data/motrpac/rat_training_6mo"

# --- (optional) project R library -------------------------------------------
# Where to install R packages (project-local lib keeps the shared module R clean).
# R_LIBS_USER="${PROJECT_ROOT}/R_libs"
